                            <button type="submit" className="btn-admin btn-admin-primary">Сохранить</button>
                        </div>
                    </form>
                </Modal>
            )}

            {confirm && (
                <ConfirmDialog
                    message="Удалить новость? Это действие нельзя отменить."
                    onConfirm={() => handleRemove(confirm)}
                    onCancel={() => setConfirm(null)}
                />
            )}
        </div>
    )
}
