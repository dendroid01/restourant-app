<file path="pages/Reviews/AdminReviews.jsx">
import { useState } from 'react'
import { useAdminStore } from '../../hooks/useAdminStore'
import ConfirmDialog from '../../components/ConfirmDialog/ConfirmDialog'
import StatusBadge from '../../components/StatusBadge/StatusBadge'
import reviewsInitial from '../../../data/reviews.json'

// Добавляем статус pending к начальным данным
const withStatus = reviewsInitial.map((r, i) => ({
    ...r,
    status: i === 1 ? 'pending' : 'approved',
}))

const FILTERS = [
    { key: 'all',      label: 'Все' },
    { key: 'pending',  label: 'На проверке' },
    { key: 'approved', label: 'Одобренные' },
    { key: 'rejected', label: 'Отклонённые' },
]

export default function AdminReviews() {
    const { items, update, remove } = useAdminStore('admin_reviews', withStatus)
    const [filter, setFilter] = useState('all')
    const [confirm, setConfirm] = useState(null)

    const filtered = filter === 'all' ? items : items.filter(r => r.status === filter)

    const stars = n => '★'.repeat(n) + '☆'.repeat(5 - n)

    return (
        <div>
            <div className="filter-btn-group">
                {FILTERS.map(f => (
                    <button key={f.key} className={`filter-pill${filter === f.key ? ' active' : ''}`}
                            onClick={() => setFilter(f.key)}>
                        {f.label}
                        <span style={{ marginLeft: 6, fontSize: 11, opacity: 0.7 }}>
              ({f.key === 'all' ? items.length : items.filter(r => r.status === f.key).length})
            </span>
                    </button>
                ))}
            </div>

            {filtered.length === 0 ? (
                <div className="empty-state"><div className="empty-state-icon">⭐</div><p>Нет отзывов</p></div>
            ) : (
                <div className="admin-table-wrap">
                    <table className="admin-table">
                        <thead>
                        <tr><th>Имя</th><th>Оценка</th><th>Отзыв</th><th>Дата</th><th>Статус</th><th>Действия</th></tr>
                        </thead>
                        <tbody>
                        {filtered.map(r => (
                            <tr key={r.id}>
                                <td style={{ fontWeight: 500 }}>{r.name}</td>
                                <td style={{ color: 'var(--gold-default)', letterSpacing: 2 }}>{stars(r.rating)}</td>
                                <td style={{ maxWidth: 260 }}>
                                    <div style={{ overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }}>{r.text_ru}</div>
                                </td>
                                <td>{r.date_ru}</td>
                                <td><StatusBadge status={r.status} /></td>
                                <td>
                                    <button className="icon-btn-admin" title="Одобрить"
                                            onClick={() => update(r.id, { status: 'approved' })}>✅</button>
                                    <button className="icon-btn-admin" title="Отклонить"
                                            onClick={() => update(r.id, { status: 'rejected' })}>❌</button>
                                    <button className="icon-btn-admin" title="Удалить"
                                            onClick={() => setConfirm(r.id)}>🗑️</button>
                                </td>
                            </tr>
                        ))}
                        </tbody>
                    </table>
                </div>
            )}

            {confirm && (
                <ConfirmDialog message="Удалить отзыв?" onConfirm={() => { remove(confirm); setConfirm(null) }} onCancel={() => setConfirm(null)} />
            )}
        </div>
    )
}
</file>

<file path="styles/admin.css">
/* ===== Admin CSS Variables ===== */
.admin-root {
    --red-default: #C0392B;
    --red-hover: #A93226;
    --bg-light: #FAF8F5;
    --bg-white: #FFFFFF;
    --text-primary: #1A1212;
    --text-secondary: #5A4A42;
    --text-tertiary: #8A8278;
    --gray-border: #D1CBC3;
    --gray-disabled-bg: #E8E4DD;
    --gold-default: #C9A84C;
    --state-success: #397339;
    --state-info: #2468AA;
    --state-error: #A93226;
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.06);
    --sidebar-width: 260px;

    font-family: 'Inter', sans-serif;
    background: var(--bg-light);
    color: var(--text-primary);
    min-height: 100vh;
}

/* ===== Layout ===== */
.admin-wrapper {
    display: flex;
    min-height: 100vh;
}

/* ===== Sidebar ===== */
.admin-sidebar {
    width: var(--sidebar-width);
    background: var(--bg-white);
    border-right: 1px solid var(--gray-border);
    padding: 28px 16px;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
}

.admin-logo {
    font-family: Georgia, serif;
    font-size: 18px;
    color: var(--gold-default);
    margin-bottom: 36px;
    padding-left: 12px;
}

.admin-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.admin-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 10px;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.18s;
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
}

.admin-nav-item:hover {
    background: var(--gray-disabled-bg);
    color: var(--text-primary);
}

.admin-nav-item.active {
    background: rgba(192, 57, 43, 0.09);
    color: var(--red-default);
    font-weight: 600;
}

.admin-nav-item.logout {
    margin-top: auto;
    color: var(--text-tertiary);
}

.admin-nav-item.logout:hover {
    color: var(--red-default);
    background: rgba(192, 57, 43, 0.06);
}

/* ===== Main Content ===== */
.admin-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
}

.admin-topbar {
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--gray-border);
    padding: 14px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 50;
}

.admin-page-title {
    font-family: Georgia, serif;
    font-size: 26px;
    font-weight: 400;
}

.admin-user-info {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-secondary);
}

.admin-avatar {
    width: 36px;
    height: 36px;
    background: var(--gray-disabled-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
}

.admin-content {
    padding: 28px;
    flex: 1;
}

/* ===== Buttons ===== */
.btn-admin {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 20px;
    border-radius: 40px;
    border: none;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.18s;
}

.btn-admin-primary {
    background: var(--red-default);
    color: white;
}
.btn-admin-primary:hover { background: var(--red-hover); }

.btn-admin-secondary {
    background: transparent;
    border: 1px solid var(--gray-border);
    color: var(--text-primary);
}
.btn-admin-secondary:hover { background: var(--gray-disabled-bg); }

.btn-admin-danger {
    background: transparent;
    border: 1px solid var(--state-error);
    color: var(--state-error);
}
.btn-admin-danger:hover {
    background: var(--state-error);
    color: white;
}

.icon-btn-admin {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 8px;
    border-radius: 6px;
    font-size: 16px;
    transition: background 0.15s;
    line-height: 1;
}
.icon-btn-admin:hover { background: var(--gray-disabled-bg); }

/* ===== Table ===== */
.admin-table-wrap {
    background: var(--bg-white);
    border-radius: 16px;
    border: 1px solid var(--gray-border);
    overflow: hidden;
}

.admin-table {
    width: 100%;
    border-collapse: collapse;
}

.admin-table th,
.admin-table td {
    padding: 14px 18px;
    text-align: left;
    border-bottom: 1px solid var(--gray-border);
    font-size: 14px;
}

.admin-table th {
    background: var(--gray-disabled-bg);
    font-weight: 600;
    color: var(--text-primary);
}

.admin-table tr:last-child td {
    border-bottom: none;
}

.admin-table tr:hover td {
    background: #fdfcfb;
}

/* ===== Stats ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
}

.stat-card {
    background: var(--bg-white);
    padding: 22px;
    border-radius: 16px;
    border: 1px solid var(--gray-border);
    box-shadow: var(--shadow-sm);
}

.stat-label {
    font-size: 13px;
    color: var(--text-secondary);
    margin-bottom: 6px;
}

.stat-value {
    font-family: Georgia, serif;
    font-size: 34px;
    color: var(--red-default);
    line-height: 1;
}

/* ===== Badges ===== */
.badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 30px;
    font-size: 12px;
    font-weight: 500;
}
.badge-success { background: rgba(57,115,57,0.12); color: var(--state-success); }
.badge-info    { background: rgba(36,104,170,0.12); color: var(--state-info); }
.badge-warning { background: rgba(201,168,76,0.12); color: var(--gold-default); }
.badge-error   { background: rgba(169,50,38,0.12);  color: var(--state-error); }
.badge-neutral { background: rgba(138,130,120,0.12); color: var(--text-tertiary); }
.badge-gold    { background: var(--gold-default); color: white; font-size: 10px; }

/* ===== Modal ===== */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
}

.modal-box {
    background: var(--bg-white);
    border-radius: 24px;
    padding: 32px;
    width: 100%;
    max-width: 640px;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: var(--shadow-md);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.modal-close {
    background: none;
    border: none;
    font-size: 26px;
    cursor: pointer;
    color: var(--text-tertiary);
    line-height: 1;
    transition: color 0.15s;
}
.modal-close:hover { color: var(--red-default); }

/* ===== Forms (admin) ===== */
.admin-form-group {
    margin-bottom: 18px;
}

.admin-form-group label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 7px;
}

.admin-input {
    width: 100%;
    padding: 9px 13px;
    border: 1px solid var(--gray-border);
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    color: var(--text-primary);
    background: var(--bg-white);
    transition: border-color 0.18s, box-shadow 0.18s;
}

.admin-input:focus {
    outline: none;
    border-color: var(--red-default);
    box-shadow: 0 0 0 3px rgba(192,57,43,0.1);
}

.admin-form-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}

/* ===== Filters ===== */
.admin-filters {
    background: var(--bg-white);
    border: 1px solid var(--gray-border);
    border-radius: 14px;
    padding: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: flex-end;
    margin-bottom: 22px;
}

.admin-filter-group {
    flex: 1;
    min-width: 140px;
}

.admin-filter-group label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 5px;
}

/* ===== Confirm dialog ===== */
.confirm-box {
    max-width: 400px;
    text-align: center;
}

.confirm-icon {
    font-size: 48px;
    margin-bottom: 16px;
}

.confirm-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 24px;
}

/* ===== Login page ===== */
.admin-login-page {
    min-height: 100vh;
    background: var(--bg-light);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.login-card {
    background: var(--bg-white);
    border-radius: 24px;
    box-shadow: var(--shadow-md);
    width: 100%;
    max-width: 440px;
    padding: 40px 36px;
}

.login-card .login-logo {
    font-family: Georgia, serif;
    font-size: 16px;
    color: var(--gold-default);
    text-align: center;
    margin-bottom: 20px;
}

.login-error {
    background: rgba(169,50,38,0.08);
    border: 1px solid rgba(169,50,38,0.2);
    color: var(--state-error);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13px;
    margin-bottom: 16px;
}

/* ===== Orders detail ===== */
.order-detail-row {
    display: flex;
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-border);
    font-size: 14px;
}

.order-detail-label {
    width: 130px;
    font-weight: 600;
    color: var(--text-secondary);
    flex-shrink: 0;
}

.order-detail-value {
    flex: 1;
    color: var(--text-primary);
}

/* ===== Empty state ===== */
.empty-state {
    text-align: center;
    padding: 60px 40px;
    color: var(--text-tertiary);
}

.empty-state-icon {
    font-size: 52px;
    margin-bottom: 16px;
    opacity: 0.6;
}

/* ===== Filter buttons (reviews) ===== */
.filter-btn-group {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 22px;
}

.filter-pill {
    padding: 7px 18px;
    border-radius: 30px;
    border: 1px solid var(--gray-border);
    background: var(--bg-white);
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.18s;
}

.filter-pill:hover { background: var(--gray-disabled-bg); }

.filter-pill.active {
    background: var(--red-default);
    color: white;
    border-color: var(--red-default);
}

/* ===== Menu admin ===== */
.menu-admin-layout {
    display: flex;
    gap: 24px;
    margin-top: 20px;
}

.categories-panel {
    width: 260px;
    flex-shrink: 0;
    background: var(--bg-white);
    border: 1px solid var(--gray-border);
    border-radius: 16px;
    padding: 18px;
}

.dishes-panel {
    flex: 1;
    background: var(--bg-white);
    border: 1px solid var(--gray-border);
    border-radius: 16px;
    padding: 18px;
}

.cat-item {
    padding: 9px 11px;
    border-radius: 9px;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.15s;
    margin-bottom: 2px;
}

.cat-item:hover { background: var(--gray-disabled-bg); }

.cat-item.active {
    background: rgba(192,57,43,0.08);
    color: var(--red-default);
    font-weight: 500;
}

.dish-img-thumb {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: var(--gray-disabled-bg);
    object-fit: cover;
}
